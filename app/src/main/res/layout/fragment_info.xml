<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Fejléc -->
    <LinearLayout
        android:id="@+id/infoHeader"
        android:layout_width="414dp"
        android:layout_height="106dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnInfoBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="SameTime Shot"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/gradient_divider"
        app:layout_constraintTop_toBottomOf="@id/infoHeader" />

    <!-- Tartalom -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── BEVEZETŐ ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="📷  Egyidejű fényképezés – egyszerre akár 8 telefonnal, ugyanabban az ezredmásodpercben."
                android:textSize="19sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5" />

            <!-- ── AZ ÖTLET HÁTTERE ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="22dp"
                    android:background="@drawable/gradient_divider" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Az ötlet háttere"
                    android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🐕  A SameTime Shot egy különleges kihívás megoldására lett megalkotva: olyan alanyok 3D modelljének elkészítése, amelyek egyetlen pillanatot sem tudnak nyugton maradni – így hagyományos fényképezéssel szinte lehetetlen lenne jó eredményt elérni."
                        android:textSize="18sp" android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.55" android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="💡  A megoldás: ha minden kamera ugyanabban a pillanatban exponál, az alany bármilyen pózban legyen, a képek mégis tökéletesen szinkronizáltak – és ebből máris elkészíthető a 3D modell."
                        android:textSize="18sp" android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.55"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── MIRE JHATÓ? ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="22dp"
                    android:background="@drawable/gradient_divider" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mire jó?"
                    android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🎯  3D modell készítés AI-jal"
                        android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="A különböző szögekből, azonos pillanatban készített képekből kiváló minőségű 3D modellek hozhatók létre – például Luma AI, Polycam, RealityCapture vagy más fotogrammetria eszközökkel."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="🐾  Mozgó állatok – A szinkron exponálás megszünteti a mozgásból eredő elmosódást és torzítást."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="🧸  Tárgyak, szobrok – Precíz, részletgazdag 3D másolatok elkészítéséhez."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.5"
                        android:text="👤  Emberek – Portré vagy egész alakos 3D scan pillanatok alatt."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── HOGYAN MŰKÖDIK? ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="22dp"
                    android:background="@drawable/gradient_divider" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hogyan működik?"
                    android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="① 📡  Válaszd ki a vezérlő telefont – ez kezeli a kapcsolatokat és itt van az exponáló gomb."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="② 📱  A többi telefon kliens módban fut – csatlakoznak a vezérlőhöz Bluetooth-on. A csatlakozás sorrendje adja meg a nevüket: Telefon 2, Telefon 3..."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="③ 🔒  Amikor minden telefon csatlakozott, a vezérlőn nyomj a &quot;Kapcsolatok véglegesítése&quot; gombra – ekkor minden telefonon beindul a kamera élőkép."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="④ 📸  Nyomd meg az exponáló gombot a vezérlőn – az összes telefon egyszerre készít képet!"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="⑤ 📤  A kliens telefonok automatikusan elküldik a képeket a vezérlőnek Bluetooth-on."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.5"
                        android:text="⑥ 🖼️  A vezérlőn a Galéria gombbal megnézheted az összes elkészült képsorozatot."
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── MŰSZAKI ADATOK ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="22dp"
                    android:background="@drawable/gradient_divider" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Műszaki adatok"
                    android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="📶  Kapcsolat:  Classic Bluetooth (RFCOMM)"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="📱  Max eszköz:  1 vezérlő + 7 kliens = 8 telefon"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="⏱️  Szinkron késleltetés:  10–50 ms"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="🖼️  Képformátum:  JPEG, maximális kamera minőség"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="💾  Mentési hely:  Képek / sametimeshot mappa (vezérlő)"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🤖  Android verzió:  12 és újabb (API 31+)"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── KAPCSOLAT ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="22dp"
                    android:background="@drawable/gradient_divider" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Visszajelzés"
                    android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="Van ötleted, észrevételed vagy hibát találtál? Írj bátran – minden visszajelzést szívesen fogadok! 🙌"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvContactEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️  szarvasrichard@gmail.com"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        android:paddingVertical="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
