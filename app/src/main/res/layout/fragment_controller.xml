<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ===== PRE-LOCK LAYOUT ===== -->
    <LinearLayout
        android:id="@+id/layoutPreLock"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="SameTime Shot"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Vezérlő • telefon1"
            android:textSize="15sp"
            android:textColor="@color/accent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#1AFFFFFF" />

        <TextView
            android:id="@+id/tvDeviceCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 7 telefon csatlakozva"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:text="Várakozás csatlakozásokra..."
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Csatlakoztasd a többi telefont a KLIENS gomb megnyomásával,\nutána nyomd meg a KAPCSOLATOK VÉGLEGESÍTÉSE gombot."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

        <Button
            android:id="@+id/btnLock"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="Kapcsolatok véglegesítése"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null"
            android:enabled="false" />

    </LinearLayout>

    <!-- ===== POST-LOCK LAYOUT ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPostLock"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Camera preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Top overlay -->
        <LinearLayout
            android:id="@+id/topOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_top_fade"
            android:padding="20dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Cím sor: app neve + telefon1 badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SameTime Shot"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <!-- Telefon 1 badge – stílusa hasonló a kezdőlap gomboknak -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_telefon1_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VEZÉRLŐ"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telefon 1"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Kamera aktív"
                android:textSize="14sp"
                android:textColor="@color/accent" />

        </LinearLayout>

        <!-- Device status chips (compact) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevicesOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/topOverlay" />

        <!-- Bottom overlay -->
        <LinearLayout
            android:id="@+id/camHudBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_bottom_fade"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Figyelmeztető sáv: képfogadás alatt látszik -->
            <LinearLayout
                android:id="@+id/layoutTransferWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_warning_banner"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_warning"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Figyelmeztetés" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="A fotók megérkezéséig nem tudsz új képet készíteni. Kis türelmet kérek..."
                    android:textSize="12sp"
                    android:textColor="#FFF8E1"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Shutter button -->
            <Button
                android:id="@+id/btnShoot"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_shutter_button"
                android:stateListAnimator="@null"
                android:text="" />

            <!-- Secondary buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnGallery"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Galéria"
                    android:textSize="16sp"
                    android:textColor="@color/accent"
                    android:background="@drawable/bg_button_secondary"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnExit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Kilépés"
                    android:textSize="14sp"
                    android:textColor="#6535D8"
                    android:background="@drawable/bg_button_exit"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
