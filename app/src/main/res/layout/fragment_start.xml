<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== Háttérkép ===== -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription=""
        android:scaleType="centerCrop"
        android:src="@drawable/app_hatter" />


    <!-- Felső sötét átmenet a cím mögé (olvashatóság) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/gradient_top_fade_dark"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Alsó átmenet a gombok mögé -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/gradient_bottom_fade_light"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ===== Alkalmazás neve – TETEJÉN ===== -->
    <LinearLayout
        android:id="@+id/titleArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SameTime Shot"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.04"
            android:shadowColor="#88000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6" />

        <View
            android:layout_width="70dp"
            android:layout_height="2dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/gradient_divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Egyidejű fényképezés 2-8 telefonnal"
            android:textSize="16sp"
            android:textColor="#CCFFFFFF"
            android:letterSpacing="0.03"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4" />

    </LinearLayout>

    <!-- ===== Info gomb a gombok felett – középre ===== -->
    <FrameLayout
        android:id="@+id/btnInfo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_info_button"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toTopOf="@id/guideText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="i"
            android:textColor="#000000"
            android:textSize="32sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- ===== Útmutató szöveg a gombok felett – sötét, mert világos háttér ===== -->
    <TextView
        android:id="@+id/guideText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="14dp"
        android:text="Válaszd ki, milyen üzemmódban\nhasználod ezt a telefont."
        android:textSize="17sp"
        android:textColor="#2A2A2A"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== Gombok – egymás mellett ===== -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="124dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="60dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Vezérlő gomb + szöveg -->
        <LinearLayout
            android:id="@+id/btnController"
            android:layout_width="0dp"
            android:layout_height="124dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="VEZÉRLŐ"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="180dp"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:text="Ez a telefon vezérli az összes telefont"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Kliens gomb + szöveg -->
        <LinearLayout
            android:id="@+id/btnClient"
            android:layout_width="0dp"
            android:layout_height="124dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_kliens"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="KLIENS"
                android:textColor="#6535D8"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:text="Csatlakozik a VEZÉRLŐ telefonhoz,\nautomatikusan fényképez"
                android:textColor="#6535D8"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Verzió -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="#66000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
