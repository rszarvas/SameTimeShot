<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Teljes képernyős fotó -->
    <ImageView
        android:id="@+id/ivFullPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true" />

    <!-- Felső sáv: vissza + fájlnév -->
    <LinearLayout
        android:id="@+id/viewerTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/gradient_top_fade"
        android:paddingBottom="16dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnViewerBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_icon_button"
            android:stateListAnimator="@null"
            android:padding="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvViewerFilename"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="fájlnév"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:singleLine="true"
                android:ellipsize="middle" />

            <TextView
                android:id="@+id/tvViewerIndex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="1 / 3"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Navigációs nyilak -->
    <Button
        android:id="@+id/btnPrev"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="‹"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_icon_button"
        android:stateListAnimator="@null"
        android:padding="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="›"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_icon_button"
        android:stateListAnimator="@null"
        android:padding="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
