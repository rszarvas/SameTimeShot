<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:background="@drawable/indicator_idle" />

        <TextView
            android:id="@+id/tvDeviceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="telefon2"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Csatlakozva"
            android:textSize="11sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/accent"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Progress bar: csak átvitel közben látszik -->
    <ProgressBar
        android:id="@+id/progressTransfer"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="8dp"
        android:progressTint="@color/gradient_start"
        android:progressBackgroundTint="@color/bg_surface"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:visibility="gone" />

</LinearLayout>
