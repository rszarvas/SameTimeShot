<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="36dp"
    android:background="@drawable/bg_card"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- Thumbnail kollázs -->
    <LinearLayout
        android:id="@+id/thumbnailContainer"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivThumb1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:background="@color/bg_surface" />

        <View
            android:id="@+id/divider1"
            android:layout_width="1.5dp"
            android:layout_height="match_parent"
            android:background="@color/bg_primary"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivThumb2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:background="@color/bg_surface"
            android:visibility="gone" />

        <View
            android:id="@+id/divider2"
            android:layout_width="1.5dp"
            android:layout_height="match_parent"
            android:background="@color/bg_primary"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivThumb3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:background="@color/bg_surface"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Gradient overlay a thumbnail alján -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/gradient_bottom_fade"
        app:layout_constraintBottom_toBottomOf="@id/thumbnailContainer" />

    <!-- Képek száma badge – jobb felső sarok -->
    <TextView
        android:id="@+id/tvPhotoCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:text="1 kép"
        android:textSize="13sp"
        android:textColor="@color/accent"
        android:background="@drawable/bg_count_badge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info sor: dátum + fájlnév prefix -->
    <LinearLayout
        android:id="@+id/infoRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/thumbnailContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDelete">

        <TextView
            android:id="@+id/tvSessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026.05.29  14:30:22"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvSessionId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="sts_20260529_143022_*"
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Kuka gomb – jobb alsó sarok -->
    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/bg_delete_btn"
        android:contentDescription="Törlés"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
