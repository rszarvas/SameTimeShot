<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/startFragment">

    <fragment
        android:id="@+id/startFragment"
        android:name="com.sametime.shot.ui.start.StartFragment"
        android:label="Start">
        <action android:id="@+id/action_startFragment_to_controllerFragment"
            app:destination="@id/controllerFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_startFragment_to_clientFragment"
            app:destination="@id/clientFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_startFragment_to_infoFragment"
            app:destination="@id/infoFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in" app:popExitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/controllerFragment"
        android:name="com.sametime.shot.ui.controller.ControllerFragment"
        android:label="Controller">
        <action android:id="@+id/action_controllerFragment_to_startFragment"
            app:destination="@id/startFragment"
            app:popUpTo="@id/startFragment" app:popUpToInclusive="true" />
        <action android:id="@+id/action_controllerFragment_to_galleryFragment"
            app:destination="@id/galleryFragment"
            app:enterAnim="@anim/slide_in_up" app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in" app:popExitAnim="@anim/slide_out_down" />
    </fragment>

    <fragment
        android:id="@+id/clientFragment"
        android:name="com.sametime.shot.ui.client.ClientFragment"
        android:label="Client">
        <action android:id="@+id/action_clientFragment_to_startFragment"
            app:destination="@id/startFragment"
            app:popUpTo="@id/startFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/galleryFragment"
        android:name="com.sametime.shot.ui.gallery.GalleryFragment"
        android:label="Gallery">
        <action android:id="@+id/action_galleryFragment_to_photoViewerFragment"
            app:destination="@id/photoViewerFragment"
            app:enterAnim="@anim/fade_in" app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in" app:popExitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/photoViewerFragment"
        android:name="com.sametime.shot.ui.gallery.PhotoViewerFragment"
        android:label="PhotoViewer" />

    <fragment
        android:id="@+id/infoFragment"
        android:name="com.sametime.shot.ui.info.InfoFragment"
        android:label="Info" />

</navigation>
