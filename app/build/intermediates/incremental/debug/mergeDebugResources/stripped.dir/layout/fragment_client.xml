<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ===== DISCOVERY ===== -->
    <LinearLayout
        android:id="@+id/layoutDiscovery"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="SameTime Shot"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Kliens mód"
            android:textSize="15sp"
            android:textColor="@color/accent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#1AFFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Válassza ki a vezérlő telefont:"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <ProgressBar
            android:id="@+id/progressDiscovery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Nem találhatók eszközök.\nIndítsa el a keresést újra."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="Eszközök keresése..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="60dp"
            android:background="@drawable/bg_button_secondary"
            android:stateListAnimator="@null"
            android:text="Keresés újraindítása"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ===== CONNECTED / WAITING / CAMERA ===== -->
    <LinearLayout
        android:id="@+id/layoutConnected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Várakozás a LOCK előtt -->
        <LinearLayout
            android:id="@+id/layoutWaiting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Csatlakozva mint"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvMyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="telefon2"
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:background="@drawable/gradient_divider"
                android:layout_marginBottom="28dp" />

            <ProgressBar
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:indeterminateTint="@color/accent"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Várakozás a vezérlőre..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Kamera aktív (LOCK után) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutCamera"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.camera.view.PreviewView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Felső overlay – ugyanolyan stílus mint a vezérlőn -->
            <LinearLayout
                android:id="@+id/clientTopOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_top_fade"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Cím sor: app neve + telefon badge (mint a vezérlőn) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SameTime Shot"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Telefon badge – fehér stílus, mint a kezdőlap Kliens gombja -->
                    <LinearLayout
                        android:id="@+id/tvClientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_client_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KLIENS"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#6535D8" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telefon 2"
                            android:textSize="11sp"
                            android:textColor="#6535D8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kamera aktív – várja a vezérlőt"
                    android:textSize="14sp"
                    android:textColor="@color/accent" />

            </LinearLayout>

            <!-- Küldési progress overlay -->
            <LinearLayout
                android:id="@+id/layoutSendProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/gradient_bottom_fade"
                android:paddingHorizontal="24dp"
                android:paddingTop="40dp"
                android:paddingBottom="24dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Kép küldése a vezérlőnek..."
                        android:textSize="13sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvSendPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressSend"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progressTint="@color/accent"
                    android:progressBackgroundTint="#2000D4FF"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
